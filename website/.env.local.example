# Resend API Key - Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxx...xxxx

# Admin email for notifications (your email)
ADMIN_EMAIL=youremail@example.com

# Admin API Key for waitlist management (generate with: openssl rand -base64 32)
ADMIN_API_KEY=your-secret-admin-key

# Vercel KV Configuration
# Get these from Vercel Dashboard > Storage > KV Database > Quickstart
KV_URL=redis://default:xxxxx@xxxxx.upstash.io:6379
KV_REST_API_URL=https://xxxxx.upstash.io
KV_REST_API_TOKEN=xxxxx
KV_REST_API_READ_ONLY_TOKEN=xxxxx

# Public entry links
NEXT_PUBLIC_AGENTM_URL=https://agentm.gradiences.xyz
NEXT_PUBLIC_AGENTM_PRO_URL=https://pro.gradiences.xyz
NEXT_PUBLIC_DOCS_URL=https://docs.gradiences.xyz
# Arena is dev-only for now; leave blank or set to localhost:5100
NEXT_PUBLIC_ARENA_URL=
