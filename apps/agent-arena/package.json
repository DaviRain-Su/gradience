{
    "name": "@gradiences/agent-arena",
    "version": "1.0.0",
    "description": "Agent Arena - Decentralized Agent task settlement with race competition",
    "keywords": [
        "pinocchio",
        "counter",
        "native",
        "solana-program"
    ],
    "license": "MIT",
    "scripts": {
        "build": "cd clients/typescript && tsc",
        "gradience": "bun ./cli/gradience.ts",
        "ci": "npm run generate-clients && npm run build && npm run lint && npm run format:check",
        "generate-clients": "tsx ./scripts/generate-clients.ts",
        "generate-idl": "cd program && cargo check --features idl",
        "test:cli": "tsx --test ./cli/gradience.test.ts",
        "test:judge-daemon": "tsx --test ./judge-daemon/src/daemon.test.ts ./judge-daemon/src/evaluators.test.ts ./judge-daemon/src/interop.test.ts ./judge-daemon/src/observability.test.ts ./judge-daemon/src/test-cases-evaluator.test.ts ./judge-daemon/src/workflow.test.ts",
        "test:sdk": "tsx --test ./clients/typescript/src/sdk.test.ts ./clients/typescript/src/wallet-adapters.test.ts",
        "judge-daemon:start": "tsx ./judge-daemon/src/main.ts",
        "judge-daemon:dspy": "python3 ./judge-daemon/dspy_service/server.py",
        "devnet:deploy": "bash ./scripts/devnet-deploy.sh",
        "devnet:rollback": "bash ./scripts/devnet-rollback.sh",
        "t70:baseline": "tsx ./scripts/t70-sprint-baseline.ts",
        "release:check-version": "tsx ./scripts/check-release-version.ts",
        "release:sdk": "bash ./scripts/release-typescript-sdk.sh",
        "release:rust-client": "bash ./scripts/release-rust-client.sh",
        "ops:alert-gate": "tsx ./scripts/t69-alert-gate.ts",
        "test:ops-alert-gate": "tsx --test ./scripts/t69-alert-gate.test.ts",
        "t46:abnormal-paths": "tsx ./scripts/t46-abnormal-paths.ts",
        "test:t46": "tsx --test ./scripts/t46-abnormal-paths.test.ts",
        "t47:pool-alt": "tsx ./scripts/t47-pool-alt.ts",
        "test:t47": "tsx --test ./scripts/t47-pool-alt.test.ts",
        "t48:event-loop": "tsx ./scripts/t48-event-loop.ts",
        "test:t48": "tsx --test ./scripts/t48-event-loop.test.ts",
        "t58:interop-audit": "tsx ./scripts/t58-interop-audit.ts",
        "test:t58": "tsx --test ./scripts/t58-interop-audit.test.ts",
        "t57:w5-stability": "tsx ./scripts/t57-w5-stability-gate.ts",
        "test:t57": "tsx --test ./scripts/t57-w5-stability-gate.test.ts",
        "drill:interop-e2e": "tsx ./scripts/drill-interop-e2e.ts",
        "test:drill-interop-e2e": "tsx --test ./scripts/drill-interop-e2e.test.ts",
        "t42:governance": "tsx ./scripts/t42-governance.ts",
        "test:t42": "tsx --test ./scripts/t42-governance.test.ts",
        "frontend:dev": "pnpm --dir ./frontend dev",
        "frontend:build": "pnpm --dir ./frontend build",
        "frontend:typecheck": "pnpm --dir ./frontend typecheck",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "devDependencies": {
        "@codama/nodes-from-anchor": "^1.3.8",
        "@codama/renderers-js": "^1.5.5",
        "@codama/renderers-rust": "^1.2.9",
        "@eslint/js": "^9.39.2",
        "@solana-program/system": "^0.10.0",
        "@solana/kit": "^5.5.1",
        "@solana/prettier-config-solana": "^0.0.6",
        "@types/node": "^20",
        "codama": "^1.5.0",
        "eslint": "^9",
        "globals": "^16.5.0",
        "prettier": "^3.6.2",
        "tsx": "^4.20.5",
        "typescript": "^5",
        "typescript-eslint": "^8.54.0"
    },
    "dependencies": {
        "@solana/web3.js": "^1.98.4",
        "@solana-program/token": "^0.12.0",
        "@sqds/multisig": "^2.1.4",
        "pg": "^8.20.0",
        "sas-lib": "^1.0.10"
    }
}
