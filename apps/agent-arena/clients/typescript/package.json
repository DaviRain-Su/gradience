{
    "name": "@gradience/sdk",
    "version": "0.1.0",
    "description": "TypeScript SDK for Gradience Protocol",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsc",
        "docs": "typedoc --out docs/api src/index.ts --plugin typedoc-plugin-markdown"
    },
    "devDependencies": {
        "typedoc": "^0.27.0",
        "typedoc-plugin-markdown": "^4.0.0"
    },
    "peerDependencies": {
        "@solana/kit": "^5.0.0"
    },
    "dependencies": {
        "@solana-program/address-lookup-table": "^0.11.0"
    }
}
