{
    "version": 2,
    "framework": "nextjs",
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "s-maxage=60, stale-while-revalidate=600" },
                { "key": "Access-Control-Allow-Origin", "value": "*" }
            ]
        }
    ]
}
