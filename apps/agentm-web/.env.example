# AgentM Web Environment Configuration
# Architecture: Local-first -- all write operations require local daemon

# Privy OAuth (deprecated -- Dynamic Labs is used now)
# NEXT_PUBLIC_PRIVY_APP_ID=

# Agent Daemon API (local only)
NEXT_PUBLIC_DAEMON_URL=http://localhost:7420
NEXT_PUBLIC_DAEMON_WS_URL=ws://localhost:7420

# Indexer REST API (optional -- for readonly fallback mode)
# If daemon is not running, web can fallback to indexer in read-only mode
NEXT_PUBLIC_INDEXER_URL=http://127.0.0.1:3001

# EVM Subgraph endpoints (The Graph)
# Per-chain endpoints allow multi-EVM support without code changes.
# Fallback to NEXT_PUBLIC_EVM_SUBGRAPH_ENDPOINT if per-chain env is absent.
NEXT_PUBLIC_EVM_SUBGRAPH_ENDPOINT_BASE_SEPOLIA=
NEXT_PUBLIC_EVM_SUBGRAPH_ENDPOINT_ARB_SEPOLIA=
NEXT_PUBLIC_EVM_SUBGRAPH_ENDPOINT=

# EVM contract configuration (defaults to Base Sepolia)
# Set these to the deployed contract addresses after running agent-layer-evm deployment.
NEXT_PUBLIC_AGENT_ARENA_EVM_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_AGENT_M_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GRADIENCE_REPUTATION_FEED_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SOCIAL_GRAPH_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_JUDGE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_EVM_RPC_ENDPOINT=https://sepolia.base.org
NEXT_PUBLIC_EVM_CHAIN_ID=84532
NEXT_PUBLIC_EVM_BLOCK_EXPLORER=https://sepolia.basescan.org

# Installation:
#   npm install -g @gradiences/agent-daemon
#   agentd start
#
# Note: Write operations (post task, send message, etc.) require local daemon.
#       Read-only browsing can work without daemon via indexer.
