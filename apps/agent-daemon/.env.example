# Agent Daemon 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# ============================================
# 基础配置 (必需)
# ============================================

# API 服务端口 (默认: 7420)
AGENTD_PORT=7420

# 绑定地址 (默认: 127.0.0.1)
# 注意: 如需绑定到 0.0.0.0，必须同时设置 AGENTD_ALLOW_ALL_INTERFACES=true
AGENTD_HOST=127.0.0.1

# 允许绑定到所有网络接口 (Docker 部署需要)
# AGENTD_ALLOW_ALL_INTERFACES=true

# 日志级别: debug, info, warn, error (默认: info)
AGENTD_LOG_LEVEL=info

# ============================================
# Chain Hub 连接
# ============================================

# Chain Hub WebSocket URL
AGENTD_CHAIN_HUB_URL=wss://indexer.gradiences.xyz/ws

# Chain Hub REST API URL
AGENTD_CHAIN_HUB_REST_URL=https://indexer.gradiences.xyz

# ============================================
# Solana 配置
# ============================================

# Solana RPC 端点
# 开发网: https://api.devnet.solana.com
# 测试网: https://api.testnet.solana.com
# 主网: https://api.mainnet-beta.solana.com
AGENTD_SOLANA_RPC_URL=https://api.devnet.solana.com

# ============================================
# X402 EVM 配置
# ============================================

# EVM RPC 端点 (X Layer Testnet)
AGENTD_EVM_RPC_URL=https://testrpc.xlayer.tech
AGENTD_EVM_CHAIN_ID=195

# X402 Settlement 合约地址 (X Layer Testnet)
AGENTD_X402_EVM_SETTLEMENT_ADDRESS=0x1Af0E217d434323f428609a42Df36B3D93c2452a

# X402 EVM 私钥 (用于 settle/rollback，需妥善保管)
# AGENTD_X402_EVM_PRIVATE_KEY=0x...

# ============================================
# 存储配置
# ============================================

# SQLite 数据库路径 (默认: ~/.agentd/data.db)
# AGENTD_DB_PATH=/custom/path/to/agentd.db

# ============================================
# A2A 通信配置
# ============================================

# 启用 A2A 通信 (默认: true)
AGENTD_A2A_ENABLED=true

# Nostr 中继服务器 (逗号分隔)
# AGENTD_NOSTR_RELAYS=wss://relay.damus.io,wss://relay.nostr.band

# Nostr 私钥 (可选，留空则自动生成)
# AGENTD_NOSTR_PRIVATE_KEY=your_private_key_hex

# 启用 XMTP 通信 (默认: false)
# AGENTD_XMTP_ENABLED=false

# ============================================
# Evaluator 评估器配置
# ============================================

# 自动评估 (默认: true)
AGENTD_AUTO_JUDGE=true

# LLM 提供商: openai, claude, moonshot (默认: openai)
AGENTD_JUDGE_PROVIDER=openai

# 评估模型 (默认: gpt-4)
# 可选: gpt-4, gpt-4-turbo, gpt-3.5-turbo, claude-3-opus, claude-3-sonnet, moonshot-v1-8k
AGENTD_JUDGE_MODEL=gpt-4

# 置信度阈值 0-1 (默认: 0.7)
AGENTD_JUDGE_CONFIDENCE_THRESHOLD=0.7

# ============================================
# LLM Provider API Keys
# 根据使用的提供商配置相应的 API Key
# ============================================

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Claude (Anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_BASE_URL=https://api.anthropic.com/v1

# Moonshot
# MOONSHOT_API_KEY=...
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ============================================
# 高级配置 (通常不需要修改)
# ============================================

# 最大 Agent 进程数 (默认: 8)
# AGENTD_MAX_AGENT_PROCESSES=8

# 心跳间隔 (毫秒, 默认: 30000)
# AGENTD_HEARTBEAT_INTERVAL=30000

# 重连基础延迟 (毫秒, 默认: 1000)
# AGENTD_RECONNECT_BASE_DELAY=1000

# 重连最大延迟 (毫秒, 默认: 30000)
# AGENTD_RECONNECT_MAX_DELAY=30000

# REST 轮询间隔 (毫秒, 默认: 5000)
# AGENTD_REST_POLLING_INTERVAL=5000
