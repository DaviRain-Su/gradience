{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "outDir": "dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node", "better-sqlite3"],
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "sourceMap": true
    },
    "include": ["src/**/*", "shared/**/*"],
    "exclude": [
        "node_modules",
        "dist",
        "tests",
        "src/**/*.test.ts",
        "src/integrations/chain-hub.ts",
        "src/bridge/**",
        "src/evaluator/**"
    ]
}
