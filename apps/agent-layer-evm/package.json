{
  "name": "@gradiences/agent-layer-evm",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:t44": "hardhat test test/ReputationVerifier.test.js",
    "test:relay": "node --test scripts/reputation-relay-server.test.js",
    "deploy:base-sepolia": "hardhat run scripts/deploy-base-sepolia.js --network baseSepolia",
    "deploy:reputation-verifier:base-sepolia": "hardhat run scripts/deploy-reputation-verifier.js --network baseSepolia",
    "sign:t44": "node scripts/sign-reputation.js",
    "relay:start": "node scripts/reputation-relay-server.js",
    "forge:build": "forge build",
    "forge:test": "forge test",
    "forge:deploy:xlayer-testnet": "source .env && forge script script/Deploy.s.sol --rpc-url xlayer-testnet --broadcast --verify",
    "forge:deploy:base-sepolia": "source .env && forge script script/Deploy.s.sol --rpc-url baseSepolia --broadcast --verify",
    "forge:anvil": "anvil --fork-url https://testrpc.xlayer.tech"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.17"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "bs58": "^6.0.0",
    "ethers": "^6.16.0",
    "tweetnacl": "^1.0.3"
  }
}
