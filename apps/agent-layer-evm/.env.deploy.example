# Gradience EVM Deployment Environment
# Copy to .env.deploy and fill in real values before running any deployment script.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
# Deployer private key (hex, with or without 0x prefix)
PRIVATE_KEY=0x...

# Oracle address for GradienceReputationFeed (defaults to deployer if unset)
ORACLE_ADDRESS=0x...

# -----------------------------------------------------------------------------
# RPC Endpoints (used by forge script --rpc-url)
# -----------------------------------------------------------------------------
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# -----------------------------------------------------------------------------
# Etherscan / Verification (optional)
# -----------------------------------------------------------------------------
BASE_SEPOLIA_VERIFIER_URL=https://api-sepolia.basescan.org/api
BASE_SEPOLIA_ETHERSCAN_KEY=

ARBITRUM_SEPOLIA_VERIFIER_URL=https://api-sepolia.arbiscan.io/api
ARBITRUM_SEPOLIA_ETHERSCAN_KEY=

# -----------------------------------------------------------------------------
# Deterministic Deploy (optional)
# -----------------------------------------------------------------------------
# If you already have a DeterministicDeployer on the target chain, set it here.
# Otherwise the DeterministicDeploy.s.sol will deploy a fresh one.
# DETERMINISTIC_DEPLOYER=0x...
