FROM node:22-alpine

WORKDIR /app

RUN corepack enable

COPY package.json ./
COPY tsconfig.json ./
COPY node-shim.d.ts ./
COPY *.ts ./
COPY adapters ./adapters

RUN pnpm install

ENV A2A_RELAY_HOST=0.0.0.0
ENV A2A_RELAY_PORT=3400
ENV A2A_RELAY_PROFILE=devnet
ENV A2A_RELAY_STORE_MODE=file
ENV A2A_RELAY_STORE_FILE=/data/relay-state.json
ENV A2A_RELAY_POSTGRES_URL=
ENV A2A_RELAY_POSTGRES_REJECT_ELEVATED_ROLE=false
ENV A2A_RELAY_POSTGRES_REQUIRE_SSL=false
ENV A2A_RELAY_POSTGRES_POOL_MAX_CONNECTIONS=10
ENV A2A_RELAY_POSTGRES_POOL_IDLE_TIMEOUT_MS=30000
ENV A2A_RELAY_POSTGRES_POOL_CONNECTION_TIMEOUT_MS=5000
ENV A2A_RELAY_POSTGRES_POOL_STATEMENT_TIMEOUT_MS=20000
ENV A2A_RELAY_POSTGRES_POOL_QUERY_TIMEOUT_MS=20000
ENV A2A_RELAY_ALERT_INTERVAL_MS=30000
ENV A2A_RELAY_ALERT_MIN_SEVERITY=warning
ENV A2A_RELAY_ALERT_MAX_DB_FAILURE_RATE=0.1
ENV A2A_RELAY_ALERT_CRITICAL_DB_FAILURE_RATE=0.25
ENV A2A_RELAY_ALERT_MAX_DB_AVG_QUERY_LATENCY_MS=300
ENV A2A_RELAY_ALERT_CRITICAL_DB_AVG_QUERY_LATENCY_MS=900
ENV A2A_RELAY_ALERT_MIN_DB_QUERY_COUNT=20
ENV A2A_RELAY_ALERT_DISPATCH_COOLDOWN_MS=60000
ENV A2A_RELAY_ALERT_RETRY_ATTEMPTS=3
ENV A2A_RELAY_ALERT_RETRY_BASE_DELAY_MS=250
ENV A2A_RELAY_ALERT_FAILURE_QUEUE_FILE=/data/alert-failures.ndjson
ENV A2A_RELAY_ALERT_REPLAY_ON_START=true

VOLUME ["/data"]
EXPOSE 3400

CMD ["pnpm", "start"]
