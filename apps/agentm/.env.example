# Agent.im Environment Variables
# Copy to .env and fill in values

# ── Auth (Privy) ──────────────────────────────────────────────────────
# Set to enable real Google OAuth + embedded Solana wallet.
# Get from https://dashboard.privy.io
# When unset, Agent.im runs in demo mode with mock auth.
VITE_PRIVY_APP_ID=

# ── Indexer ───────────────────────────────────────────────────────────
# Base URL for the Gradience Indexer API.
VITE_INDEXER_BASE_URL=http://127.0.0.1:3001

# ── Demo ──────────────────────────────────────────────────────────────
# Set to '0' to skip indexer validation in stage-a demo script.
AGENT_IM_DEMO_REQUIRE_INDEXER=1
