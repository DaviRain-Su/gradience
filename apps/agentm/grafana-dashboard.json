{
  "dashboard": {
    "id": null,
    "title": "A2A Router Dashboard",
    "tags": ["a2a", "router", "metrics"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Messages Sent",
        "type": "stat",
        "targets": [
          {
            "expr": "a2a_messages_sent_total",
            "legendFormat": "Total"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Messages Received",
        "type": "stat",
        "targets": [
          {
            "expr": "a2a_messages_received_total",
            "legendFormat": "Total"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 }
      },
      {
        "id": 3,
        "title": "Message Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "a2a_message_latency_ms",
            "legendFormat": "Latency (ms)"
          }
        ],
        "yAxes": [
          { "label": "Milliseconds", "min": 0 }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "id": 4,
        "title": "Protocol Connections",
        "type": "graph",
        "targets": [
          {
            "expr": "a2a_protocol_connections",
            "legendFormat": "{{protocol}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "id": 5,
        "title": "Active Subscriptions",
        "type": "stat",
        "targets": [
          {
            "expr": "a2a_active_subscriptions",
            "legendFormat": "Subscriptions"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 }
      },
      {
        "id": 6,
        "title": "Discovered Agents",
        "type": "stat",
        "targets": [
          {
            "expr": "a2a_discovered_agents_total",
            "legendFormat": "Agents"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 }
      },
      {
        "id": 7,
        "title": "Router Status",
        "type": "stat",
        "targets": [
          {
            "expr": "a2a_router_up",
            "legendFormat": "Up"
          }
        ],
        "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 }
      },
      {
        "id": 8,
        "title": "Protocol Errors",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(a2a_protocol_errors_total[5m])",
            "legendFormat": "{{protocol}}"
          }
        ],
        "gridPos": { "h": 8, "w": 20, "x": 4, "y": 16 }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "5s"
  }
}
