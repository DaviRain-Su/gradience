# Gradience Production Environment Variables
# Copy this file to .env.prod and fill in real values before deploying.

# -----------------------------------------------------------------------------
# PostgreSQL (Indexer)
# -----------------------------------------------------------------------------
POSTGRES_USER=gradience
POSTGRES_PASSWORD=change_me_to_a_strong_password

# -----------------------------------------------------------------------------
# Indexer (Solana on-chain listener)
# -----------------------------------------------------------------------------
SOLANA_WS_URL=wss://api.devnet.solana.com
# Replace with the deployed Agent Arena program ID
SOLANA_PROGRAM_ID=5CUY2V1odYZghA54WH7YQRPzh3JaKhe1S84CRbeKfVYs
SOLANA_COMMITMENT=confirmed

# -----------------------------------------------------------------------------
# Agent Daemon (runtime environment variables)
# -----------------------------------------------------------------------------
AGENTD_CHAIN_HUB_URL=wss://indexer.gradiences.xyz/ws
AGENTD_CHAIN_HUB_REST_URL=https://indexer.gradiences.xyz
AGENTD_SOLANA_RPC_URL=https://api.devnet.solana.com
AGENTD_HOST=0.0.0.0
AGENTD_PORT=4001
AGENTD_ALLOW_ALL_INTERFACES=true

# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Payments / Bridge
# -----------------------------------------------------------------------------
AGENTD_BRIDGE_ENABLED=true
AGENTD_BRIDGE_PROGRAM_ID=5CUY2V1odYZghA54WH7YQRPzh3JaKhe1S84CRbeKfVYs
