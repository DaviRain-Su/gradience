# AgentD Production Environment Configuration
# Copy this file to .env.prod and fill in your actual values

# =============================================================================
# Solana Configuration
# =============================================================================

# RPC endpoint (mainnet-beta for production)
AGENTD_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet private key (base58 encoded) - DO NOT COMMIT THE REAL VALUE
# This is the authority wallet for the daemon
AGENTD_WALLET_PRIVATE_KEY=

# =============================================================================
# Program IDs
# =============================================================================

# Arena Program ID (devnet: 5CUY2V1odYZghA54WH7YQRPzh3JaKhe1S84CRbeKfVYs)
AGENTD_ARENA_PROGRAM_ID=5CUY2V1odYZghA54WH7YQRPzh3JaKhe1S84CRbeKfVYs

# AgentM Core Program ID (devnet: 2stkfkFaFLUvSR9yydmfQ7pZReo2M38zcVtL1QffCyDA)
# For mainnet, replace with your mainnet deployment
AGENTD_AGENTM_CORE_PROGRAM_ID=2stkfkFaFLUvSR9yydmfQ7pZReo2M38zcVtL1QffCyDA

# =============================================================================
# API Keys (Production)
# =============================================================================

# OpenAI API Key
OPENAI_API_KEY=

# Optional: Helius RPC API Key (recommended for production)
HELIUS_API_KEY=

# =============================================================================
# Deployment Info
# =============================================================================
