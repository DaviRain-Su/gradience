# Gradience -- Production Environment Variables
#
# Copy to deploy/.env.prod and fill in real values.
# NEVER commit .env.prod to version control.

# -- PostgreSQL (shared by indexer-db and daemon-db)
POSTGRES_USER=gradience
POSTGRES_PASSWORD=changeme_strong_password_here

# -- Solana RPC
SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com

# -- Agent Daemon
AGENTD_LOG_LEVEL=info

# -- SSH / Deployment (used by deploy-core.sh)
DROPLET_IP=YOUR_DROPLET_IP
DEPLOY_USER=root
DEPLOY_DIR=/opt/gradience
