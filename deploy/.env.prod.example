# ─────────────────────────────────────────────────────────────────────────────
# Gradience — Production Environment Variables
#
# Copy this file to deploy/.env.prod on the droplet and fill in real values.
# NEVER commit .env.prod to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=gradience
# Required — pick a strong random password, e.g.: openssl rand -hex 32
POSTGRES_PASSWORD=changeme_strong_password_here

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Devnet for initial deployment; switch to mainnet-beta or a private RPC later
SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com
# SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# ── Agent Daemon ──────────────────────────────────────────────────────────────
AGENTD_LOG_LEVEL=info
# Optional: WebSocket URL of the Chain Hub service
# AGENTD_CHAIN_HUB_URL=ws://indexer-mock:3001/ws

# ── SSH / Deployment ──────────────────────────────────────────────────────────
# Used by deploy-digitalocean.sh — fill in before running the script
DROPLET_IP=YOUR_DROPLET_IP
DEPLOY_USER=root
# Path on the droplet where the repo will live
DEPLOY_DIR=/opt/gradience

# ── SSL / Certbot ─────────────────────────────────────────────────────────────
# Must match the server_name blocks in nginx.conf
CERTBOT_EMAIL=your-email@example.com
CERTBOT_DOMAINS="api.gradiences.xyz,daemon.gradiences.xyz"
