{
  "name": "@gradiences/xmtp-adapter",
  "version": "0.1.0",
  "description": "XMTP-based Agent-to-Agent messaging adapter for the Gradience protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "xmtp",
    "a2a",
    "agent",
    "messaging",
    "encrypted",
    "gradience",
    "solana"
  ],
  "author": "Gradience",
  "license": "MIT",
  "dependencies": {
    "@xmtp/xmtp-js": "^13.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"]
  },
  "files": [
    "dist",
    "README.md"
  ]
}
