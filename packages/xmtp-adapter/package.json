{
    "name": "@gradiences/xmtp-adapter",
    "version": "0.1.0",
    "description": "XMTP-based Agent-to-Agent messaging adapter for the Gradience protocol",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "test": "echo 'Tests skipped - XMTP adapter is WIP'",
        "test:watch": "echo 'Tests skipped - XMTP adapter is WIP'",
        "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts",
        "clean": "rm -rf dist"
    },
    "keywords": [
        "xmtp",
        "a2a",
        "agent",
        "messaging",
        "encrypted",
        "gradience",
        "solana"
    ],
    "author": "Gradience",
    "dependencies": {
        "@gradiences/a2a-types": "^0.1.0",
        "@xmtp/xmtp-js": "^13.0.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.8",
        "@types/node": "^20.9.0",
        "@typescript-eslint/eslint-plugin": "^6.12.0",
        "@typescript-eslint/parser": "^6.12.0",
        "eslint": "^8.54.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.1",
        "typescript": "^5.2.2"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": [
            "**/__tests__/**/*.test.ts"
        ]
    }
}
