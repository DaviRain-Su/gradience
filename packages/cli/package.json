{
  "name": "@gradiences/cli",
  "version": "0.1.0",
  "description": "Command-line interface for Gradience protocol",
  "type": "module",
  "bin": {
    "gradience": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest --run --passWithNoTests",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "keywords": [
    "gradience",
    "cli",
    "solana",
    "blockchain",
    "agents"
  ],
  "dependencies": {
    "@gradiences/sdk": "workspace:*",
    "@solana/kit": "^5.5.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gradience-protocol/gradience.git",
    "directory": "packages/cli"
  }
}