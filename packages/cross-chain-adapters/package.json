{
  "name": "@gradiences/cross-chain-adapters",
  "version": "1.0.0",
  "description": "Cross-chain bridge adapters for LayerZero, Wormhole, and DeBridge",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters/*": {
      "import": "./dist/adapters/*.js",
      "types": "./dist/adapters/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts"
  },
  "keywords": [
    "cross-chain",
    "layerzero",
    "wormhole",
    "debridge",
    "bridge",
    "solana",
    "ethereum"
  ],
  "author": "Gradience Protocol",
  "license": "MIT",
  "dependencies": {
    "@gradiences/a2a-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@layerzerolabs/lz-v2-utilities": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@layerzerolabs/lz-v2-utilities": {
      "optional": true
    }
  }
}
