{
    "name": "@gradiences/soul-engine",
    "version": "0.1.0",
    "description": "Soul Profile engine for non-financial A2A social matching",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./types": {
            "import": "./dist/types.js",
            "types": "./dist/types.d.ts"
        },
        "./parser": {
            "import": "./dist/parser.js",
            "types": "./dist/parser.d.ts"
        },
        "./storage": {
            "import": "./dist/storage.js",
            "types": "./dist/storage.d.ts"
        },
        "./probe": {
            "import": "./dist/probe.js",
            "types": "./dist/probe.d.ts"
        },
        "./matching": {
            "import": "./dist/matching/index.js",
            "types": "./dist/matching/index.d.ts"
        },
        "./llm-config": {
            "import": "./dist/llm-config.js",
            "types": "./dist/llm-config.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "type-check": "tsc --noEmit",
        "test": "vitest --run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@xenova/transformers": "^2.17.2",
        "gray-matter": "^4.0.3",
        "marked": "^12.0.2",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.9.0",
        "vitest": "^1.6.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "gradience",
        "soul",
        "social",
        "matching",
        "a2a"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/gradience-protocol/gradience.git",
        "directory": "packages/soul-engine"
    }
}
