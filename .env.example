# Production Environment Configuration
# Gradience Protocol - Local-First Architecture

# ============================================
# Agent Daemon (Required for full functionality)
# ============================================
AGENTD_PORT=7420
AGENTD_HOST=127.0.0.1
AGENTD_LOG_LEVEL=info

# Solana Devnet
AGENTD_SOLANA_RPC_URL=https://api.devnet.solana.com

# Program IDs (Devnet)
AGENTD_ARENA_PROGRAM_ID=5CUY2V1odYZghA54WH7YQRPzh3JaKhe1S84CRbeKfVYs
AGENTD_CHAIN_HUB_PROGRAM_ID=6G39W7JGQz7A6L5dAvotFuRP9UbFdCJg2BqDuj6WJWec
AGENTD_A2A_PROGRAM_ID=FPaeaqQCziLidnwTtQndUB1SiaqBuBUad6UCnshfMd3H
AGENTD_AGENTM_CORE_PROGRAM_ID=2stkfkFaFLUvSR9yydmfQ7pZReo2M38zcVtL1QffCyDA

# Indexer Sync (for cached data)
AGENTD_INDEXER_URL=https://api.gradiences.xyz/indexer
AGENTD_INDEXER_SYNC_INTERVAL=30000

# A2A Protocol
AGENTD_A2A_ENABLED=true
AGENTD_NOSTR_RELAYS=wss://relay.damus.io,wss://relay.nostr.band
AGENTD_XMTP_ENV=production

# ============================================
# Web Frontend (Read-only mode when no daemon)
# ============================================
NEXT_PUBLIC_DAEMON_URL=http://localhost:7420
NEXT_PUBLIC_DAEMON_WS_URL=ws://localhost:7420
NEXT_PUBLIC_INDEXER_URL=https://api.gradiences.xyz/indexer

# Wallet (Dynamic Labs)
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# LLM (for judge/evaluator)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# Installation
# ============================================
# 1. Install daemon: npm install -g @gradiences/agent-daemon
# 2. Start daemon: agentd start
# 3. Open web: https://agentm.gradiences.xyz
# 4. Or local dev: cd apps/agentm-web && pnpm dev
