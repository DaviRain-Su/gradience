# syntax=docker/dockerfile:1
# apps/agentm-web -- Next.js 15 user-facing app (port 5200)

ARG NODE_VERSION=22

# -- Stage 1: Prune monorepo
FROM node:${NODE_VERSION}-alpine AS pruner
WORKDIR /app
COPY . .
RUN npx --yes turbo@2 prune @gradiences/agentm-web --docker

# -- Stage 2: Install dependencies
FROM node:${NODE_VERSION}-alpine AS deps
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.1.4 --activate
RUN apk add --no-cache python3 make g++ linux-headers eudev-dev libusb-dev
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
RUN pnpm install --frozen-lockfile

# -- Stage 3: Build Next.js
FROM node:${NODE_VERSION}-alpine AS builder
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.1.4 --activate
COPY --from=deps /app/ .
COPY --from=pruner /app/out/full/ .

ARG NEXT_PUBLIC_INDEXER_URL=http://indexer-mock:3001
ARG NEXT_PUBLIC_GRADIENCE_INDEXER_ENDPOINT=http://indexer-mock:3001
ARG NEXT_PUBLIC_PRIVY_APP_ID
ARG NEXT_PUBLIC_GRADIENCE_RPC_ENDPOINT
ENV NEXT_PUBLIC_INDEXER_URL=$NEXT_PUBLIC_INDEXER_URL
ENV NEXT_PUBLIC_GRADIENCE_INDEXER_ENDPOINT=$NEXT_PUBLIC_GRADIENCE_INDEXER_ENDPOINT
ENV NEXT_PUBLIC_PRIVY_APP_ID=$NEXT_PUBLIC_PRIVY_APP_ID
ENV NEXT_PUBLIC_GRADIENCE_RPC_ENDPOINT=$NEXT_PUBLIC_GRADIENCE_RPC_ENDPOINT

RUN pnpm --filter @gradiences/agentm-web build

# -- Stage 4: Runtime with production next install
FROM node:${NODE_VERSION}-alpine AS runner
WORKDIR /app/apps/agentm-web
ENV NODE_ENV=production
ENV PORT=5200
ENV HOSTNAME=0.0.0.0

# Copy built Next.js output
COPY --from=builder /app/apps/agentm-web/.next ./.next
COPY --from=builder /app/apps/agentm-web/next.config.ts ./next.config.ts
COPY --from=builder /app/apps/agentm-web/package.json ./package.json
COPY --from=builder /app/apps/agentm-web/public* ./public/

# Install only production next runtime
RUN npm install --ignore-scripts next@15 react react-dom

EXPOSE 5200
CMD ["npx", "next", "start", "-p", "5200"]
