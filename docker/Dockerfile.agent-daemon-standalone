# Standalone agent-daemon Dockerfile
# Build context: agent-daemon directory
#
#   docker build -f Dockerfile.agent-daemon-standalone -t gradience/agent-daemon .

ARG NODE_VERSION=22

FROM node:${NODE_VERSION}-alpine AS builder
WORKDIR /app
RUN apk add --no-cache python3 make g++
COPY package.json tsconfig.json tsconfig.publish.json ./
RUN npm install
COPY src/ src/
COPY shared/ shared/
RUN npx tsc -p tsconfig.publish.json

FROM node:${NODE_VERSION}-alpine AS runner
WORKDIR /app
RUN apk add --no-cache libstdc++ libgcc

ENV NODE_ENV=production
ENV AGENTD_HOST=0.0.0.0
ENV AGENTD_PORT=4001
ENV AGENTD_LOG_LEVEL=info
ENV AGENTD_DB_PATH=/data/agentd.db

COPY package.json ./
RUN npm install --omit=dev
COPY --from=builder /app/dist/ ./dist/

VOLUME ["/data"]
EXPOSE 4001
CMD ["node", "dist/src/index.js", "start"]
